version: "3.9"

services:
  postgres:
    image: postgres:16
    environment:
      POSTGRES_USER: parking
      POSTGRES_PASSWORD: {{ postgres_password }}
      POSTGRES_DB: parking
    ports:
      - "5433:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data

  keycloak:
    image: quay.io/keycloak/keycloak:24.0.5
    command: start-dev --import-realm
    environment:
      KEYCLOAK_ADMIN: {{ keycloak_admin_user }}
      KEYCLOAK_ADMIN_PASSWORD: {{ keycloak_admin_password }}
    ports:
      - "8080:8080"
    volumes:
      - ../parking-auth/realm:/opt/keycloak/data/import:ro

  mailhog:
    image: mailhog/mailhog
    ports:
      - "1025:1025"
      - "8025:8025"

  minio:
    image: minio/minio
    command: server /data --console-address ":9001"
    environment:
      MINIO_ROOT_USER: {{ minio_root_user }}
      MINIO_ROOT_PASSWORD: {{ minio_root_password }}
    ports:
      - "9000:9000"
      - "9001:9001"
    volumes:
      - minio_data:/data

  core-api:
    image: {{ core_api_image }}
    environment:
      ASPNETCORE_URLS: http://+:8080
      ConnectionStrings__Default: Host=postgres;Port=5432;Database=parking;Username=parking;Password={{ postgres_password }}
      Auth__Authority: http://keycloak:8080/realms/parking
      Auth__Audience: parking-api
      Storage__Provider: S3
      Storage__RootPath: /app/storage
      Storage__Endpoint: http://minio:9000
      Storage__AccessKey: {{ minio_root_user }}
      Storage__SecretKey: {{ minio_root_password }}
      Storage__Bucket: parking-docs
      Storage__ForcePathStyle: "true"
    ports:
      - "5000:8080"
    depends_on:
      - postgres
      - keycloak
      - minio
    volumes:
      - core_storage:/app/storage

  email-worker:
    image: {{ email_worker_image }}
    environment:
      ConnectionStrings__Default: Host=postgres;Port=5432;Database=parking;Username=parking;Password={{ postgres_password }}
      Email__Host: mailhog
      Email__Port: 1025
      Email__From: noreply@parking.local
    depends_on:
      - postgres
      - mailhog

volumes:
  postgres_data:
  minio_data:
  core_storage:
